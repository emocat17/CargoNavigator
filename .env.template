# ============================================
# CargoNavigator 部署配置
# 使用方法: 复制此文件为 .env，填写 __必填__ 项
# ============================================

# ---- 必填 ----

# 高德地图 Web服务 API Key（用于后端路线规划/地理编码）
# 获取: https://console.amap.com/dev/key/app → 选择"Web服务"
AMAP_API_KEY=your_amap_web_service_key

# ---- AI 智能助手（可选，不填则 AI 问答不可用）----

# LLM 提供商配置（默认 DeepSeek，可切换 OpenAI / Qwen / 等）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- MaxKB 知识库（可选，不填则法规查询不可用）----

# 方式 1（推荐）: 填写账号密码，运行 bootstrap_maxkb.py 自动获取其余配置
#   docker compose --profile kb up -d        # 启动 MaxKB
#   # 浏览器访问 http://localhost:18090 完成首次初始化
#   python backend/bootstrap_maxkb.py        # 自动登录并填写以下 4 项
MAXKB_PORT=18090
MAXKB_USERNAME=admin
MAXKB_PASSWORD=

# 方式 2（手动）: 从 MaxKB 后台逐项复制
#   API Key: MaxKB 后台 → 设置 → API Key
#   Chat API: MaxKB 后台 → 应用 → 发布 → Chat API 地址
#   Dataset ID: MaxKB 后台 → 知识库 → 复制 ID
#   Session Token: 浏览器 F12 → Application → Cookies → Authorization
MAXKB_API_KEY=
MAXKB_CHAT_API_URL=
MAXKB_DATASET_ID=
MAXKB_SESSION_TOKEN=
