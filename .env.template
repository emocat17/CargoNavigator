# ============================================
# CargoNavigator 部署配置
# 使用方法: 复制此文件为 .env，填写 __必填__ 项
# ============================================

# ---- 必填 ----

# 高德地图 Web服务 API Key（用于后端路线规划/地理编码）
# 获取: https://console.amap.com/dev/key/app → 选择"Web服务"
AMAP_API_KEY=your_amap_web_service_key

# ---- AI 智能助手（可选，不填则 AI 问答不可用）----

# DeepSeek API Key
# 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ---- MaxKB 知识库（可选，不填则法规查询不可用）----

# 先启动 MaxKB: docker compose --profile kb up -d
# 访问 http://localhost:18090 完成初始化，然后获取以下信息填入:
#   API Key: MaxKB 后台 → 设置 → API Key
#   Chat API: MaxKB 后台 → 应用 → 发布 → Chat API 地址
#   Dataset ID: MaxKB 后台 → 知识库 → 复制 ID
#   Session Token: 浏览器 F12 → Application → Cookies → Authorization
MAXKB_PORT=18090
MAXKB_API_KEY=
MAXKB_CHAT_API_URL=
MAXKB_DATASET_ID=
MAXKB_SESSION_TOKEN=
