# CargoNavigator Backend Configuration
# Copy to .env and fill in required values

# ---- Required ----
# Amap Web Service API Key (for route planning/geocoding)
AMAP_API_KEY=your_amap_web_service_key

# ---- LLM / AI Assistant (optional) ----
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- MaxKB Knowledge Base (optional) ----
MAXKB_PORT=18090
MAXKB_BASE_URL=http://localhost:18090
MAXKB_USERNAME=admin
MAXKB_PASSWORD=
MAXKB_API_KEY=
MAXKB_CHAT_API_URL=
MAXKB_DATASET_ID=
MAXKB_SESSION_TOKEN=

# ---- Cost Estimation (all have defaults) ----
# FUEL_PRICE_PER_L=7.5
# ESCORT_VEHICLE_COST_PER_DAY=800
# POLICE_ESCORT_COST=2000
# DEFAULT_INSURANCE_COST=1500

# ---- Database (default SQLite) ----
# DATABASE_URL=sqlite:///./data/cargo_navigator.db
