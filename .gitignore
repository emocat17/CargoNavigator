# ============================================
# Project: Generated / Runtime Data
# ============================================
# Bridge DB is tracked — it's the canonical data store (13.9MB SQLite)
# Regenerate via: python -m data.migrate_data (requires XLSX source files)
backend/data/_*.txt
backend/data/_*.json
backend/spider/data/

# SQLite WAL (Write-Ahead Log) — runtime transient files
*.db-shm
*.db-wal

# Application runtime database (schema is in schema.sql)
backend/data/cargo_navigator.db

# ============================================
# Project: XLSX source data (migration input only, not for runtime)
# ============================================
backend/data/source/
docs/reference/bridge-source-data/
docs/archive/**/facility_parameters/

# ============================================
# OS / Temp
# ============================================
*.tmp
~$*
