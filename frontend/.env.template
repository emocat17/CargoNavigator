# ============================================
# CargoNavigator 前端配置
# 使用方法: 复制此文件为 .env，填写 __必填__ 项
# ============================================

# ---- 必填 ----

# 高德地图 JS API Key（用于前端地图显示）
# 注意: 此 Key 类型必须选择"Web端(JS API)"，与后端 Web服务 Key 不同
# 获取: https://console.amap.com/dev/key/app → 选择"Web端(JS API)"
VITE_AMAP_KEY=your_amap_js_api_key

# ---- 可选 ----

# JS API 安全密钥（与 Key 配套的 AMap Security Code）
VITE_AMAP_SECURITY_CODE=

# 后端 API 地址（默认自动检测，无需修改）
# VITE_API_BASE=http://localhost:19876
